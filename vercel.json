{
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "public",
  "crons": [
    {
      "path": "/api/cron/monitor",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/",
      "destination": "/app/index.html"
    }
  ]
}
