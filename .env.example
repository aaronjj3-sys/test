# Copy to .env.local and fill in. NEVER commit .env.local.

# Apollo.io - server-side only. Master API key required for mixed_people/api_search.
APOLLO_API_KEY=

# Supabase. The service role key must NEVER reach the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase browser auth. These are public anon values used to generate app/config.js during build.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:8000

# Stripe - later, for billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth for the future "Connect Gmail" flow (separate from Google login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/callback

# LinkedIn OAuth (identity connect). Create the app at developer.linkedin.com,
# request "Sign In with LinkedIn using OpenID Connect", then fill these in.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional override; defaults to <origin>/api/linkedin/callback
LINKEDIN_REDIRECT_URI=

# Optional: upgrades resume parsing + writing-style learning to Claude
# (claude-haiku-4-5, pennies per profile). Everything still works without it.
ANTHROPIC_API_KEY=
