# Copy to .env.local and fill in. NEVER commit .env.local.

# Apollo.io - server-side only. Master API key required for mixed_people/api_search.
APOLLO_API_KEY=

# Supabase. The service role key must NEVER reach the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:8000

# Stripe - later, for billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth for the future "Connect Gmail" flow (separate from Google login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
